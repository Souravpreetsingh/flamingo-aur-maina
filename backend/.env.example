# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/luxestay_db

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=LuxeStay Hospitality API
VERSION=1.0.0
DEBUG=True
CORS_ORIGINS=["http://localhost:5500","http://127.0.0.1:5500"]

# Bcrypt
BCRYPT_ROUNDS=12
